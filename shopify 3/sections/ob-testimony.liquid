{% comment %}OUTDOOR BILLS — Testimony Section | sections/ob-testimony.liquid
Links to sandlotrevival.org
{% endcomment %}

<section class="ob-testimony">
  <div class="ob-test-bg"></div>
  <div class="ob-test-inner">
    <div class="ob-test-header ob-reveal">
      <span class="ob-label" style="color:var(--ob-peach);">{{ section.settings.eyebrow }}</span>
      <h2 class="ob-test-title">{{ section.settings.title_plain }} <em>{{ section.settings.title_italic }}</em></h2>
      <div class="ob-divider" style="background:var(--ob-khaki);margin:1rem auto;"></div>
    </div>

    <div class="ob-test-grid">
      {% for block in section.blocks %}
        <div class="ob-test-card ob-reveal ob-d{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="ob-test-quote-mark">"</div>
          <p class="ob-test-quote">{{ block.settings.quote }}</p>
          <div class="ob-test-author">
            {% if block.settings.avatar %}
              <img src="{{ block.settings.avatar | img_url: '80x80', crop: 'center' }}" alt="{{ block.settings.name }}" class="ob-test-avatar"/>
            {% else %}
              <div class="ob-test-avatar-placeholder">{{ block.settings.name | slice: 0 }}</div>
            {% endif %}
            <div>
              <div class="ob-test-name">{{ block.settings.name }}</div>
              <div class="ob-test-location">{{ block.settings.location }}</div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.show_sandlot_link %}
    <div class="ob-test-sandlot ob-reveal">
      <p>{{ section.settings.sandlot_text }}</p>
      <a href="https://sandlotrevival.org" class="ob-test-sandlot-btn" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        Visit Sandlot Revival
      </a>
    </div>
    {% endif %}
  </div>
</section>

<style>
.ob-testimony{position:relative;background:var(--ob-earth);padding:6rem 3.5rem;overflow:hidden;}
.ob-test-bg{position:absolute;inset:0;background:radial-gradient(ellipse at 50% 0%,rgba(59,92,114,0.18) 0%,transparent 70%);pointer-events:none;}
.ob-test-inner{position:relative;z-index:1;max-width:1200px;margin:0 auto;}
.ob-test-header{text-align:center;margin-bottom:3.5rem;}
.ob-test-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.4rem,5vw,4rem);line-height:1;color:#fff;letter-spacing:0.04em;}
.ob-test-title em{font-family:'Playfair Display',serif;font-style:italic;color:var(--ob-khaki);}
.ob-test-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;}
.ob-test-card{background:rgba(255,255,255,0.04);border:1px solid rgba(196,170,122,0.15);border-radius:8px;padding:2rem;position:relative;transition:border-color 0.3s,background 0.3s;}
.ob-test-card:hover{border-color:rgba(196,170,122,0.35);background:rgba(255,255,255,0.07);}
.ob-test-quote-mark{font-family:'Playfair Display',serif;font-size:5rem;line-height:0.8;color:var(--ob-sienna);opacity:0.6;margin-bottom:0.5rem;display:block;}
.ob-test-quote{font-family:'Libre Baskerville',serif;font-style:italic;font-size:0.96rem;line-height:1.85;color:rgba(240,235,224,0.75);margin:0 0 1.5rem;}
.ob-test-author{display:flex;align-items:center;gap:0.85rem;}
.ob-test-avatar{width:44px;height:44px;border-radius:50%;object-fit:cover;border:2px solid rgba(196,170,122,0.3);}
.ob-test-avatar-placeholder{width:44px;height:44px;border-radius:50%;background:var(--ob-river);display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:1.2rem;color:#fff;flex-shrink:0;}
.ob-test-name{font-family:'DM Sans',sans-serif;font-weight:500;font-size:0.85rem;color:rgba(240,235,224,0.9);letter-spacing:0.05em;}
.ob-test-location{font-size:0.72rem;color:rgba(240,235,224,0.4);letter-spacing:0.1em;text-transform:uppercase;margin-top:0.1rem;}
.ob-test-sandlot{text-align:center;margin-top:3.5rem;padding-top:3rem;border-top:1px solid rgba(196,170,122,0.15);}
.ob-test-sandlot p{font-family:'Libre Baskerville',serif;font-style:italic;color:rgba(240,235,224,0.55);margin-bottom:1.2rem;font-size:0.95rem;}
.ob-test-sandlot-btn{display:inline-flex;align-items:center;gap:0.5rem;padding:0.85rem 2rem;background:transparent;border:1.5px solid rgba(196,170,122,0.4);color:var(--ob-khaki);font-family:'DM Sans',sans-serif;font-size:0.75rem;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:all 0.25s;}
.ob-test-sandlot-btn:hover{border-color:var(--ob-khaki);background:rgba(196,170,122,0.1);transform:translateY(-2px);}
@media(max-width:900px){.ob-testimony{padding:4rem 1.5rem;}.ob-test-grid{grid-template-columns:1fr;gap:1rem;}}
@media(max-width:600px){.ob-test-grid{grid-template-columns:1fr;}}
</style>

{% schema %}
{
  "name": "OB Testimony",
  "settings": [
    { "type": "text",     "id": "eyebrow",        "label": "Eyebrow",          "default": "Community" },
    { "type": "text",     "id": "title_plain",    "label": "Title (plain)",    "default": "What People" },
    { "type": "text",     "id": "title_italic",   "label": "Title (italic)",   "default": "Are Saying" },
    { "type": "checkbox", "id": "show_sandlot_link", "label": "Show Sandlot Revival Link", "default": true },
    { "type": "textarea", "id": "sandlot_text",   "label": "Text above Sandlot link", "default": "Outdoor Bills is proud to support Sandlot Revival — faith, community, and the outdoors." }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea",     "id": "quote",    "label": "Quote",        "default": "Outdoor Bills isn't just gear — it's a mindset. Every time I hit the water I'm reminded why we get outside." },
        { "type": "text",         "id": "name",     "label": "Name",         "default": "Jake M." },
        { "type": "text",         "id": "location", "label": "Location",     "default": "Georgia" },
        { "type": "image_picker", "id": "avatar",   "label": "Avatar Photo (optional)" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [{
    "name": "OB Testimony",
    "blocks": [
      { "type": "testimonial", "settings": { "quote": "Outdoor Bills isn't just gear — it's a mindset. Every time I hit the water I'm reminded why we get outside.", "name": "Jake M.", "location": "Georgia" }},
      { "type": "testimonial", "settings": { "quote": "Finally a brand that gets it. Built for people who actually live outdoors, not just talk about it.", "name": "Sara T.", "location": "Tennessee" }},
      { "type": "testimonial", "settings": { "quote": "The cap is perfect. Wore it on a 3-day float trip and it held up through everything. Highly recommend.", "name": "Chris R.", "location": "Alabama" }}
    ]
  }]
}
{% endschema %}
