{% comment %}OUTDOOR BILLS — Shop Page | sections/ob-page-shop.liquid{% endcomment %}

<!-- SHOP HERO -->
<div class="ob-cat-hero">
  <div class="ob-cat-hero-bg" {% if section.settings.hero_image %}style="background-image:linear-gradient(to bottom,rgba(42,31,20,0.25) 0%,rgba(42,31,20,0.72) 100%),url('{{ section.settings.hero_image | img_url: '2000x' }}');"{% endif %}></div>
  <div class="ob-cat-hero-content ob-reveal">
    <span class="ob-label" style="color:var(--ob-peach);">{{ section.settings.eyebrow | default: 'The Collection' }}</span>
    <h1 class="ob-cat-hero-title">The <em>Shop</em></h1>
    <p>{{ section.settings.hero_subtitle | default: 'Built for people who actually go outside.' }}</p>
  </div>
</div>

<!-- STICKY FILTER BAR -->
<div class="ob-filter-bar">
  <div class="ob-filter-inner">
    <span class="ob-filter-label">Browse:</span>
    <div class="ob-filter-btns">
      <a href="/collections/all"         class="ob-filter-btn ob-filter-active">All Products</a>
      <a href="/collections/hats"        class="ob-filter-btn">Hats &amp; Caps</a>
      <a href="/collections/apparel"     class="ob-filter-btn">Apparel</a>
      <a href="/collections/accessories" class="ob-filter-btn">Accessories</a>
      <a href="/collections/new-arrivals"class="ob-filter-btn">New Arrivals</a>
      <a href="/collections/sale"        class="ob-filter-btn ob-filter-sale">Sale</a>
    </div>
  </div>
</div>

<!-- FEATURED COLLECTION CALLOUTS -->
<section class="ob-shop-callouts">
  <div class="ob-shop-callouts-hdr ob-reveal">
    <span class="ob-label">{{ section.settings.callouts_eyebrow | default: 'Shop By Category' }}</span>
    <h2 class="ob-title">{{ section.settings.callouts_title | default: 'Find Your' }} <em>{{ section.settings.callouts_italic | default: 'Fit' }}</em></h2>
  </div>
  <div class="ob-callouts-grid">
    <a href="/collections/hats" class="ob-callout-card ob-callout-lg ob-reveal">
      {% if section.settings.cat1_image %}<img src="{{ section.settings.cat1_image | img_url: '1000x' }}" alt="Hats &amp; Caps"/>{% endif %}
      <div class="ob-callout-body">
        <span class="ob-callout-eyebrow">Collection</span>
        <div class="ob-callout-name">Hats &amp; Caps</div>
        <div class="ob-callout-sub">{{ section.settings.cat1_desc | default: 'Classic OB snapbacks, bucket hats, and field caps.' }}</div>
        <span class="ob-callout-cta">Shop Now →</span>
      </div>
    </a>
    <div class="ob-callout-stack">
      <a href="/collections/apparel" class="ob-callout-card ob-reveal ob-d1">
        {% if section.settings.cat2_image %}<img src="{{ section.settings.cat2_image | img_url: '800x' }}" alt="Apparel"/>{% endif %}
        <div class="ob-callout-body">
          <span class="ob-callout-eyebrow">Collection</span>
          <div class="ob-callout-name">Apparel</div>
          <div class="ob-callout-sub">{{ section.settings.cat2_desc | default: 'Tees, hoodies, and layers made for the field.' }}</div>
          <span class="ob-callout-cta">Shop Now →</span>
        </div>
      </a>
      <a href="/collections/accessories" class="ob-callout-card ob-reveal ob-d2">
        {% if section.settings.cat3_image %}<img src="{{ section.settings.cat3_image | img_url: '800x' }}" alt="Accessories"/>{% endif %}
        <div class="ob-callout-body">
          <span class="ob-callout-eyebrow">Collection</span>
          <div class="ob-callout-name">Accessories</div>
          <div class="ob-callout-sub">{{ section.settings.cat3_desc | default: 'Stickers, patches, and everything else.' }}</div>
          <span class="ob-callout-cta">Shop Now →</span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- FEATURED PRODUCTS STRIP -->
{% assign feat_col = collections[section.settings.featured_collection] %}
{% if feat_col != blank and section.settings.show_featured %}
<section class="ob-shop-feat">
  <div class="ob-shop-feat-hdr ob-reveal">
    <div>
      <span class="ob-label">{{ section.settings.featured_eyebrow | default: 'Featured' }}</span>
      <h2 class="ob-title">Best <em>Sellers</em></h2>
    </div>
    <a href="/collections/all" class="ob-btn-out">View All</a>
  </div>
  <div class="ob-shop-feat-grid">
    {% for product in feat_col.products limit: section.settings.featured_count %}
      <a href="{{ product.url }}" class="ob-prod-card ob-reveal ob-d{{ forloop.index }}">
        {% if product.featured_image %}<img src="{{ product.featured_image | img_url: '600x800', crop: 'center' }}" alt="{{ product.featured_image.alt | escape }}"/>{% endif %}
        {% if forloop.first %}<span class="ob-prod-badge">Best Seller</span>{% endif %}
        <div class="ob-prod-info">
          <div class="ob-prod-name">{{ product.title }}</div>
          <div class="ob-prod-price">{{ product.price | money }}</div>
        </div>
      </a>
    {% endfor %}
  </div>
</section>
{% endif %}

<style>
.ob-cat-hero{position:relative;height:38vh;min-height:280px;display:flex;align-items:flex-end;overflow:hidden;}
.ob-cat-hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;background-color:var(--ob-earth);}
.ob-cat-hero-content{position:relative;z-index:2;padding:0 3.5rem 2.8rem;max-width:680px;}
.ob-cat-hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.5rem,8vw,7rem);line-height:0.9;color:#fff;margin:0.3rem 0 0.5rem;}
.ob-cat-hero-title em{font-family:'Playfair Display',serif;font-style:italic;color:var(--ob-khaki);}
.ob-cat-hero-content p{font-family:'Libre Baskerville',serif;font-style:italic;color:rgba(240,235,224,0.75);font-size:0.95rem;}

.ob-filter-bar{background:var(--ob-card);border-bottom:1px solid var(--ob-border);position:sticky;top:72px;z-index:100;}
.ob-filter-inner{display:flex;align-items:center;gap:1.5rem;padding:0.85rem 3.5rem;overflow-x:auto;scrollbar-width:none;}
.ob-filter-inner::-webkit-scrollbar{display:none;}
.ob-filter-label{font-size:0.62rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--ob-muted);white-space:nowrap;font-family:'DM Sans',sans-serif;}
.ob-filter-btns{display:flex;gap:0.45rem;}
.ob-filter-btn{font-size:0.68rem;letter-spacing:0.14em;text-transform:uppercase;font-weight:500;color:var(--ob-muted);text-decoration:none;padding:0.38rem 1rem;border-radius:30px;border:1px solid transparent;transition:all 0.2s;white-space:nowrap;font-family:'DM Sans',sans-serif;}
.ob-filter-btn:hover{color:var(--ob-river);border-color:rgba(59,92,114,0.28);}
.ob-filter-active{color:#fff!important;background:var(--ob-river)!important;border-color:var(--ob-river)!important;}
.ob-filter-sale{color:var(--ob-sienna)!important;}
.ob-filter-sale:hover{border-color:var(--ob-sienna)!important;}

.ob-shop-callouts{padding:5rem 3.5rem;background:var(--ob-cream);}
.ob-shop-callouts-hdr{margin-bottom:2.5rem;}
.ob-callouts-grid{display:grid;grid-template-columns:1.1fr 1fr;gap:4px;background:var(--ob-border);}
.ob-callout-stack{display:flex;flex-direction:column;gap:4px;}
.ob-callout-card{position:relative;overflow:hidden;text-decoration:none;display:block;background:var(--ob-earth);min-height:280px;}
.ob-callout-lg{min-height:580px;}
.ob-callout-card img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:saturate(0.78) brightness(0.68);transition:transform 0.55s,filter 0.4s;}
.ob-callout-card:hover img{transform:scale(1.05);filter:saturate(0.9) brightness(0.72);}
.ob-callout-body{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:flex-end;padding:2rem 1.8rem;background:linear-gradient(to top,rgba(42,31,20,0.88) 0%,rgba(42,31,20,0.08) 55%,transparent 100%);}
.ob-callout-eyebrow{font-size:0.58rem;letter-spacing:0.32em;text-transform:uppercase;color:var(--ob-peach);margin-bottom:0.25rem;display:block;}
.ob-callout-name{font-family:'Bebas Neue',sans-serif;font-size:2.2rem;letter-spacing:0.06em;color:#fff;line-height:0.95;margin-bottom:0.4rem;transition:color 0.2s;}
.ob-callout-card:hover .ob-callout-name{color:var(--ob-khaki);}
.ob-callout-sub{font-family:'Libre Baskerville',serif;font-style:italic;font-size:0.82rem;color:rgba(240,235,224,0.6);margin-bottom:0.9rem;line-height:1.5;}
.ob-callout-cta{font-size:0.68rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--ob-khaki);font-family:'DM Sans',sans-serif;font-weight:500;transition:letter-spacing 0.2s;}
.ob-callout-card:hover .ob-callout-cta{letter-spacing:0.26em;}

.ob-shop-feat{padding:5rem 3.5rem;background:var(--ob-card);}
.ob-shop-feat-hdr{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:2.5rem;flex-wrap:wrap;gap:1rem;}
.ob-shop-feat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;background:var(--ob-border);}
.ob-prod-card{background:var(--ob-card);position:relative;overflow:hidden;aspect-ratio:3/4;cursor:pointer;text-decoration:none;display:block;}
.ob-prod-card img{width:100%;height:100%;object-fit:cover;filter:saturate(0.88);transition:transform 0.5s,filter 0.4s;}
.ob-prod-card:hover img{transform:scale(1.07);filter:saturate(1.05);}
.ob-prod-info{position:absolute;bottom:0;left:0;right:0;padding:1.5rem;background:linear-gradient(to top,rgba(42,31,20,0.92),transparent);transform:translateY(22%);transition:transform 0.4s;}
.ob-prod-card:hover .ob-prod-info{transform:translateY(0);}
.ob-prod-name{font-family:'Bebas Neue',sans-serif;font-size:1.15rem;letter-spacing:0.08em;color:#fff;margin-bottom:0.25rem;}
.ob-prod-price{font-size:0.82rem;color:var(--ob-khaki);}
.ob-prod-badge{position:absolute;top:0.8rem;right:0.8rem;background:var(--ob-sienna);color:#fff;font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;padding:0.22rem 0.6rem;border-radius:2px;}

@media(max-width:1000px){.ob-shop-feat-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:900px){
  .ob-cat-hero-content{padding:0 1.5rem 2rem;}
  .ob-filter-inner{padding:0.85rem 1.5rem;}
  .ob-shop-callouts,.ob-shop-feat{padding:3.5rem 1.5rem;}
  .ob-callouts-grid{grid-template-columns:1fr;}
  .ob-callout-lg{min-height:320px;}
}
</style>

{% schema %}
{
  "name": "OB Shop Page",
  "settings": [
    { "type": "header",       "content": "Hero" },
    { "type": "image_picker", "id": "hero_image",          "label": "Hero Image" },
    { "type": "text",         "id": "eyebrow",             "label": "Eyebrow",              "default": "The Collection" },
    { "type": "text",         "id": "hero_subtitle",       "label": "Subtitle",             "default": "Built for people who actually go outside." },
    { "type": "header",       "content": "Category Callouts" },
    { "type": "text",         "id": "callouts_eyebrow",    "label": "Section Eyebrow",      "default": "Shop By Category" },
    { "type": "text",         "id": "callouts_title",      "label": "Title (plain)",        "default": "Find Your" },
    { "type": "text",         "id": "callouts_italic",     "label": "Title (italic)",       "default": "Fit" },
    { "type": "image_picker", "id": "cat1_image",          "label": "Hats & Caps Image" },
    { "type": "text",         "id": "cat1_desc",           "label": "Hats Description",     "default": "Classic OB snapbacks, bucket hats, and field caps." },
    { "type": "image_picker", "id": "cat2_image",          "label": "Apparel Image" },
    { "type": "text",         "id": "cat2_desc",           "label": "Apparel Description",  "default": "Tees, hoodies, and layers made for the field." },
    { "type": "image_picker", "id": "cat3_image",          "label": "Accessories Image" },
    { "type": "text",         "id": "cat3_desc",           "label": "Accessories Desc",     "default": "Stickers, patches, and everything else." },
    { "type": "header",       "content": "Featured Products" },
    { "type": "checkbox",     "id": "show_featured",       "label": "Show Featured Strip",  "default": true },
    { "type": "text",         "id": "featured_eyebrow",    "label": "Strip Eyebrow",        "default": "Featured" },
    { "type": "collection",   "id": "featured_collection", "label": "Collection to Feature" },
    { "type": "range",        "id": "featured_count",      "label": "Number of Products",   "min": 2, "max": 8, "step": 2, "default": 4 }
  ],
  "presets": [{ "name": "OB Shop Page" }]
}
{% endschema %}
