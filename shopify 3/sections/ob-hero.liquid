{% comment %}OUTDOOR BILLS — Hero | sections/ob-hero.liquid{% endcomment %}

<section class="ob-hero">
  <div class="ob-hero-bg" {% if section.settings.hero_image %}style="background-image:linear-gradient(to bottom,rgba(42,31,20,0.18) 0%,rgba(42,31,20,0) 25%,rgba(59,92,114,0.28) 65%,rgba(42,31,20,0.94) 100%),url('{{ section.settings.hero_image | img_url: '2000x' }}');"{% endif %}></div>
  <div class="ob-hero-content">
    <span class="ob-hero-eyebrow">{{ section.settings.eyebrow }}</span>
    <h1 class="ob-hero-title">{{ section.settings.title_line1 }}<br/><span>{{ section.settings.title_line2 }}</span></h1>
    <p class="ob-hero-sub">{{ section.settings.subtitle }}</p>
    <div class="ob-hero-ctas">
      <a href="/collections/all" class="ob-btn">{{ section.settings.cta1_text }}</a>
      <a href="/pages/about" class="ob-btn-out ob-btn-out-lt">{{ section.settings.cta2_text }}</a>
    </div>
  </div>
  <div class="ob-hero-scroll"><div class="ob-scroll-line"></div><span>Scroll</span></div>
</section>

<!-- Rotating bordered marquee -->
<div class="ob-marquee-wrap">
  <div class="ob-marquee-track" id="ob-marquee">
    <span>Find Joy</span><span class="ob-mdot">◆</span>
    <span>Get Outdoors</span><span class="ob-mdot">◆</span>
    <span>Fish On</span><span class="ob-mdot">◆</span>
    <span>Hunt More</span><span class="ob-mdot">◆</span>
    <span>Find Joy</span><span class="ob-mdot">◆</span>
    <span>Get Outdoors</span><span class="ob-mdot">◆</span>
    <span>Fish On</span><span class="ob-mdot">◆</span>
    <span>Hunt More</span><span class="ob-mdot">◆</span>
    <span>Find Joy</span><span class="ob-mdot">◆</span>
    <span>Get Outdoors</span><span class="ob-mdot">◆</span>
    <span>Fish On</span><span class="ob-mdot">◆</span>
    <span>Hunt More</span><span class="ob-mdot">◆</span>
  </div>
</div>

<style>
/* ── HERO ── */
.ob-hero{position:relative;height:100vh;min-height:700px;display:flex;flex-direction:column;justify-content:flex-end;overflow:hidden;}
.ob-hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;background-color:var(--ob-earth);}
.ob-hero-content{position:relative;z-index:2;padding:0 3.5rem 5.5rem;max-width:820px;}

/* EST 2023 — sky blue, slightly brighter, subtle border for visibility */
.ob-hero-eyebrow{
  font-size:0.72rem;
  letter-spacing:0.45em;
  text-transform:uppercase;
  color: #8DC8E0;
  margin-bottom:1rem;
  display:inline-block;
  opacity:0;
  animation:ob-fadeUp 0.8s 0.3s forwards;
  padding:0.2rem 0.75rem;
  border:1px solid rgba(141,200,224,0.3);
  border-radius:30px;
  background:rgba(59,92,114,0.2);
  backdrop-filter:blur(6px);
}
.ob-hero-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(5rem,13vw,12rem);line-height:0.88;letter-spacing:0.02em;color:#fff;margin-bottom:1.5rem;opacity:0;animation:ob-fadeUp 0.9s 0.5s forwards;}
.ob-hero-title span{color:var(--ob-khaki);}
.ob-hero-sub{font-family:'Libre Baskerville',serif;font-style:italic;font-size:1.1rem;color:rgba(240,235,224,0.8);margin-bottom:2.5rem;opacity:0;animation:ob-fadeUp 0.9s 0.7s forwards;}
.ob-hero-ctas{display:flex;gap:1rem;flex-wrap:wrap;opacity:0;animation:ob-fadeUp 0.9s 0.9s forwards;}
.ob-hero-scroll{position:absolute;bottom:2.5rem;right:3.5rem;display:flex;flex-direction:column;align-items:center;gap:0.6rem;opacity:0;animation:ob-fadeIn 1s 1.5s forwards;}
.ob-hero-scroll span{font-size:0.6rem;letter-spacing:0.3em;text-transform:uppercase;color:rgba(240,235,224,0.5);writing-mode:vertical-rl;}
.ob-scroll-line{width:1px;height:55px;background:linear-gradient(to bottom,var(--ob-khaki),transparent);animation:ob-scrollPulse 2s ease-in-out infinite;}

/* ── MARQUEE — rotating blue border style ── */
.ob-marquee-wrap{
  background:var(--ob-earth);
  padding:0;
  overflow:hidden;
  white-space:nowrap;
  border-top:1px solid rgba(59,92,114,0.4);
  border-bottom:1px solid rgba(59,92,114,0.4);
  position:relative;
}
.ob-marquee-wrap::before,.ob-marquee-wrap::after{
  content:'';
  position:absolute;
  top:0;bottom:0;width:3px;
  background:var(--ob-river);
  z-index:2;
  animation:ob-borderPulse 3s ease-in-out infinite;
}
.ob-marquee-wrap::before{left:0;}
.ob-marquee-wrap::after{right:0;}
.ob-marquee-inner{
  padding:0.9rem 0;
  border-top:1px solid rgba(196,170,122,0.12);
  border-bottom:1px solid rgba(196,170,122,0.12);
}
.ob-marquee-track{display:inline-flex;animation:ob-marquee 20s linear infinite;}
.ob-marquee-track span{
  font-family:'Bebas Neue',sans-serif;
  font-size:1rem;
  letter-spacing:0.32em;
  color:rgba(240,235,224,0.85);
  padding:0 2.8rem;
  text-transform:uppercase;
}
.ob-mdot{color:var(--ob-river)!important;padding:0 0.5rem!important;font-size:0.7rem!important;vertical-align:middle;}

@keyframes ob-fadeUp{from{opacity:0;transform:translateY(28px);}to{opacity:1;transform:translateY(0);}}
@keyframes ob-fadeIn{from{opacity:0;}to{opacity:1;}}
@keyframes ob-marquee{from{transform:translateX(0);}to{transform:translateX(-50%);}}
@keyframes ob-scrollPulse{0%,100%{opacity:0.3;}50%{opacity:1;}}
@keyframes ob-borderPulse{0%,100%{opacity:0.4;background:var(--ob-river);}50%{opacity:1;background:var(--ob-sky);}}
@media(max-width:900px){.ob-hero-content{padding:0 1.5rem 3.5rem;}.ob-hero-scroll{display:none;}}
</style>

{% schema %}
{
  "name": "OB Hero",
  "settings": [
    { "type": "image_picker", "id": "hero_image",  "label": "Hero Background Image" },
    { "type": "text",         "id": "eyebrow",     "label": "Est. Badge Text", "default": "Est. 2023" },
    { "type": "text",         "id": "title_line1", "label": "Title Line 1",    "default": "Outdoor" },
    { "type": "text",         "id": "title_line2", "label": "Title Line 2",    "default": "Bills" },
    { "type": "text",         "id": "subtitle",    "label": "Subtitle",        "default": "Finding Joy In The Outdoors" },
    { "type": "text",         "id": "cta1_text",   "label": "Button 1",        "default": "Shop Collection" },
    { "type": "text",         "id": "cta2_text",   "label": "Button 2",        "default": "Our Story" }
  ],
  "presets": [{ "name": "OB Hero" }]
}
{% endschema %}
