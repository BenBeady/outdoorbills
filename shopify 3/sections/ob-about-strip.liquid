{% comment %}OUTDOOR BILLS — About Strip | sections/ob-about-strip.liquid{% endcomment %}
<section class="ob-about">
  <div class="ob-about-img">
    {% if section.settings.about_image %}<img src="{{ section.settings.about_image | img_url: '900x' }}" alt="{{ section.settings.image_alt }}"/>{% endif %}
  </div>
  <div class="ob-about-text ob-reveal">
    <span class="ob-label">{{ section.settings.eyebrow }}</span>
    <h2 class="ob-title">{{ section.settings.title_plain }} <em>{{ section.settings.title_italic }}</em></h2>
    <div class="ob-divider"></div>
    <div class="ob-about-quote"><p>"{{ section.settings.pull_quote }}"</p></div>
    <p>{{ section.settings.body_text_1 }}</p>
    <p>{{ section.settings.body_text_2 }}</p>
    <a href="/pages/about" class="ob-btn">Read More</a>
  </div>
</section>
<style>
.ob-about{display:grid;grid-template-columns:1fr 1fr;min-height:620px;background:var(--ob-card);}
.ob-about-img{position:relative;overflow:hidden;min-height:450px;}
.ob-about-img img{width:100%;height:100%;object-fit:cover;filter:saturate(0.9) contrast(1.05);}
.ob-about-img::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(59,92,114,0.18),rgba(74,103,65,0.12));}
.ob-about-text{display:flex;flex-direction:column;justify-content:center;padding:5rem 4.5rem;}
.ob-about-text p{font-family:'Libre Baskerville',serif;font-size:0.98rem;line-height:1.92;color:var(--ob-muted);margin:0.8rem 0;}
.ob-about-text .ob-btn{align-self:flex-start;margin-top:1rem;}
.ob-about-quote{border-left:3px solid var(--ob-sienna);padding-left:1.4rem;margin:1.5rem 0;}
.ob-about-quote p{font-style:italic!important;font-size:1.08rem!important;color:var(--ob-river)!important;margin:0!important;font-family:'Libre Baskerville',serif!important;}
@media(max-width:900px){.ob-about{grid-template-columns:1fr;}.ob-about-img{min-height:300px;}.ob-about-text{padding:3rem 1.5rem;}}
</style>
{% schema %}{"name":"OB About Strip","settings":[{"type":"image_picker","id":"about_image","label":"About Image"},{"type":"text","id":"image_alt","label":"Image Alt","default":"Outdoor Bills story"},{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Our Roots"},{"type":"text","id":"title_plain","label":"Title (plain)","default":"About"},{"type":"text","id":"title_italic","label":"Title (italic)","default":"Us"},{"type":"text","id":"pull_quote","label":"Pull Quote","default":"The outdoors became more than a hobby — it became a way of life."},{"type":"textarea","id":"body_text_1","label":"Paragraph 1","default":"Born in the outdoors of Middle Georgia, Outdoor Bills is about more than gear — it's about chasing adventure around the world and sharing every moment along the way."},{"type":"textarea","id":"body_text_2","label":"Paragraph 2","default":"Time spent in nature has shaped who we are, teaching us to slow down, appreciate creation, and find peace away from the noise of everyday life."}],"presets":[{"name":"OB About Strip"}]}{% endschema %}
