{% comment %}OUTDOOR BILLS — About Gallery | sections/ob-about-gallery.liquid{% endcomment %}
<section class="ob-agallery">
  <div class="ob-agallery-hdr ob-reveal">
    <span class="ob-label">{{ section.settings.eyebrow | default: 'Life Outdoors' }}</span>
    <h2 class="ob-title">On The <em>Road</em></h2>
  </div>
  <div class="ob-agallery-grid">
    {% for block in section.blocks %}
      <div class="ob-agphoto ob-reveal" {{ block.shopify_attributes }}>
        {% if block.settings.photo %}
          <img src="{{ block.settings.photo | img_url: '700x' }}" alt="{{ block.settings.caption | default: 'Outdoor Bills' }}"/>
          {% if block.settings.caption != blank %}
            <div class="ob-agcap">{{ block.settings.caption }}</div>
          {% endif %}
        {% endif %}
      </div>
    {% endfor %}
  </div>
</section>
<style>
.ob-agallery{padding:5rem 3.5rem;background:var(--ob-cream);}
.ob-agallery-hdr{margin-bottom:2.5rem;}
.ob-agallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;}
.ob-agphoto{position:relative;overflow:hidden;aspect-ratio:4/3;border-radius:3px;}
.ob-agphoto img{width:100%;height:100%;object-fit:cover;filter:saturate(0.84);transition:transform 0.5s,filter 0.4s;}
.ob-agphoto:hover img{transform:scale(1.06);filter:saturate(1.06);}
.ob-agcap{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(to top,rgba(42,31,20,0.78),transparent);padding:0.9rem 1.1rem 0.65rem;font-size:0.68rem;letter-spacing:0.12em;color:rgba(240,235,224,0.82);text-transform:uppercase;font-family:'DM Sans',sans-serif;}
@media(max-width:900px){.ob-agallery{padding:3.5rem 1.5rem;}.ob-agallery-grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:500px){.ob-agallery-grid{grid-template-columns:1fr;}}
</style>
{% schema %}
{
  "name": "OB About — Gallery",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Life Outdoors" }
  ],
  "blocks": [
    { "type": "photo", "name": "Photo", "settings": [
      { "type": "image_picker", "id": "photo",   "label": "Photo" },
      { "type": "text",         "id": "caption", "label": "Caption (optional)" }
    ]}
  ],
  "max_blocks": 9,
  "presets": [{ "name": "OB About — Gallery", "blocks": [
    {"type":"photo"},{"type":"photo"},{"type":"photo"},
    {"type":"photo"},{"type":"photo"},{"type":"photo"}
  ]}]
}
{% endschema %}
