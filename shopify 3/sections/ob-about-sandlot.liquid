{% comment %}OUTDOOR BILLS — About Sandlot Revival | sections/ob-about-sandlot.liquid{% endcomment %}
<section class="ob-sandlot">
  {% if section.settings.sandlot_image %}
    <div class="ob-sandlot-img ob-reveal">
      <img src="{{ section.settings.sandlot_image | img_url: '900x' }}" alt="Sandlot Revival"/>
    </div>
  {% endif %}
  <div class="ob-sandlot-text ob-reveal ob-d1">
    <span class="ob-label" style="color:rgba(196,170,122,0.85);">{{ section.settings.eyebrow | default: 'Our Community' }}</span>
    <h2 class="ob-title" style="color:#fff;">Sandlot <em>Revival</em></h2>
    <div class="ob-divider" style="background:var(--ob-khaki);"></div>
    <p>{{ section.settings.para1 | default: 'Sandlot Revival is about more than the outdoors. It\'s a community rooted in faith, friendship, and the belief that life is best lived together — outside.' }}</p>
    <p>{{ section.settings.para2 | default: 'Outdoor Bills is proud to be part of that mission. A portion of what we do goes right back into building that community and spreading that message.' }}</p>
    <a href="https://sandlotrevival.org" class="ob-sandlot-btn" target="_blank" rel="noopener">
      Visit sandlotrevival.org
      <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
  </div>
</section>
<style>
.ob-sandlot{background:var(--ob-moss);padding:5.5rem 3.5rem;display:grid;grid-template-columns:1fr 1fr;gap:4.5rem;align-items:center;}
.ob-sandlot-img{border-radius:6px;overflow:hidden;aspect-ratio:4/3;}
.ob-sandlot-img img{width:100%;height:100%;object-fit:cover;}
.ob-sandlot-text p{font-family:'Libre Baskerville',serif;font-style:italic;color:rgba(240,235,224,0.68);line-height:1.88;font-size:0.96rem;margin:0.7rem 0;}
.ob-sandlot-btn{display:inline-flex;align-items:center;gap:0.5rem;margin-top:1.6rem;padding:0.85rem 2rem;border:1.5px solid rgba(196,170,122,0.4);color:var(--ob-khaki);font-family:'DM Sans',sans-serif;font-size:0.75rem;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:all 0.25s;}
.ob-sandlot-btn:hover{border-color:var(--ob-khaki);background:rgba(196,170,122,0.1);transform:translateY(-2px);}
@media(max-width:900px){.ob-sandlot{grid-template-columns:1fr;padding:4rem 1.5rem;gap:2.5rem;}}
</style>
{% schema %}
{
  "name": "OB About — Sandlot Revival",
  "settings": [
    { "type": "image_picker", "id": "sandlot_image", "label": "Sandlot Photo" },
    { "type": "text",         "id": "eyebrow",       "label": "Eyebrow",      "default": "Our Community" },
    { "type": "textarea",     "id": "para1",         "label": "Paragraph 1",  "default": "Sandlot Revival is about more than the outdoors. It's a community rooted in faith, friendship, and the belief that life is best lived together — outside." },
    { "type": "textarea",     "id": "para2",         "label": "Paragraph 2",  "default": "Outdoor Bills is proud to be part of that mission. A portion of what we do goes right back into building that community and spreading that message." }
  ],
  "presets": [{ "name": "OB About — Sandlot Revival" }]
}
{% endschema %}
