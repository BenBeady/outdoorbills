{% comment %}OUTDOOR BILLS — Social Grid | sections/ob-social-grid.liquid
Upload your own photos in each block. Links go to your real Instagram.
{% endcomment %}
<section class="ob-social">
  <div class="ob-social-hdr ob-reveal">
    <span class="ob-label">{{ section.settings.eyebrow }}</span>
    <h2 class="ob-title">{{ section.settings.title_plain }} <em>{{ section.settings.title_italic }}</em></h2>
    <a href="https://instagram.com/{{ section.settings.instagram_handle }}" class="ob-social-handle" target="_blank" rel="noopener">@{{ section.settings.instagram_handle }}</a>
  </div>
  <div class="ob-social-grid">
    {% for block in section.blocks %}
      <a href="https://instagram.com/{{ section.settings.instagram_handle }}" class="ob-social-cell" target="_blank" rel="noopener" {{ block.shopify_attributes }}>
        {% if block.settings.image %}
          <img src="{{ block.settings.image | img_url: '400x400', crop: 'center' }}" alt="{{ block.settings.alt | default: 'Outdoor Bills on Instagram' }}"/>
        {% else %}
          <div class="ob-soc-placeholder"><span>+</span></div>
        {% endif %}
        <div class="ob-soc-ov">
          <svg viewBox="0 0 24 24" width="28" height="28" fill="white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </div>
      </a>
    {% endfor %}
  </div>
  <div class="ob-social-cta ob-reveal">
    <a href="https://instagram.com/{{ section.settings.instagram_handle }}" class="ob-btn-out" target="_blank" rel="noopener">Follow @{{ section.settings.instagram_handle }} on Instagram</a>
  </div>
</section>
<style>
.ob-social{padding:5rem 0 0;background:var(--ob-cream);text-align:center;}
.ob-social-hdr{padding:0 3.5rem 2.5rem;}
.ob-social-handle{display:inline-block;margin-top:0.7rem;font-size:0.82rem;letter-spacing:0.1em;color:var(--ob-river);text-decoration:none;transition:color 0.2s;}
.ob-social-handle:hover{color:var(--ob-sienna);}
.ob-social-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:3px;}
.ob-social-cell{aspect-ratio:1;overflow:hidden;position:relative;display:block;background:var(--ob-border);}
.ob-social-cell img{width:100%;height:100%;object-fit:cover;filter:saturate(0.75) brightness(0.9);transition:filter 0.35s,transform 0.4s;}
.ob-social-cell:hover img{filter:saturate(1.1) brightness(1.02);transform:scale(1.07);}
.ob-soc-placeholder{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:var(--ob-border);color:var(--ob-muted);font-size:2rem;}
.ob-soc-ov{position:absolute;inset:0;background:rgba(59,92,114,0.45);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.3s;}
.ob-social-cell:hover .ob-soc-ov{opacity:1;}
.ob-social-cta{padding:2.5rem 3.5rem 4rem;}
@media(max-width:900px){.ob-social-grid{grid-template-columns:repeat(3,1fr);}.ob-social-hdr{padding:0 1.5rem 2rem;}.ob-social-cta{padding:2rem 1.5rem 3rem;}}
@media(max-width:500px){.ob-social-grid{grid-template-columns:repeat(2,1fr);}}
</style>
{% schema %}{"name":"OB Social Grid","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Instagram"},{"type":"text","id":"title_plain","label":"Title (plain)","default":"See Our"},{"type":"text","id":"title_italic","label":"Title (italic)","default":"Socials"},{"type":"text","id":"instagram_handle","label":"Instagram Handle (no @)","default":"outdoorbills"}],"blocks":[{"type":"photo","name":"Photo","settings":[{"type":"image_picker","id":"image","label":"Upload Your Photo"},{"type":"text","id":"alt","label":"Alt Text","default":"Outdoor Bills Instagram"}]}],"max_blocks":12,"presets":[{"name":"OB Social Grid","blocks":[{"type":"photo"},{"type":"photo"},{"type":"photo"},{"type":"photo"},{"type":"photo"},{"type":"photo"}]}]}{% endschema %}
