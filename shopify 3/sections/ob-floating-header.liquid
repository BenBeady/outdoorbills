{% comment %}OUTDOOR BILLS — Floating Header | sections/ob-floating-header.liquid
Add to layout/theme.liquid right after <body>: {% section 'ob-floating-header' %}
{% endcomment %}

<header class="ob-header" id="ob-floating-header">
  <a href="{{ routes.root_url }}" class="ob-logo">
    {% if section.settings.logo_image %}
      <img src="{{ section.settings.logo_image | img_url: '200x' }}" alt="{{ shop.name }}" class="ob-logo-img"/>
    {% else %}
      {{ section.settings.logo_text | default: shop.name }}
    {% endif %}
  </a>
  <ul class="ob-nav-links">
    <li><a href="/collections/all">Shop</a></li>
    <li><a href="/pages/about">About</a></li>
    <li><a href="https://www.youtube.com/@bill_leroy" target="_blank" rel="noopener">YouTube</a></li>
    <li><a href="/pages/contact">Contact</a></li>
  </ul>
  <a href="{{ routes.cart_url }}" class="ob-nav-cart">Bag ({{ cart.item_count }})</a>
</header>

<style>
.ob-header{position:fixed;top:1rem;left:50%;transform:translateX(-50%);z-index:200;width:calc(100% - 3rem);max-width:1200px;display:flex;align-items:center;justify-content:space-between;padding:0.85rem 1.8rem;background:rgba(42,31,20,0.5);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid rgba(196,170,122,0.18);border-radius:60px;transition:background 0.4s,box-shadow 0.4s;}
.ob-header.ob-scrolled{background:rgba(42,31,20,0.94);box-shadow:0 8px 40px rgba(0,0,0,0.28);}
.ob-logo{font-family:'Bebas Neue',sans-serif;font-size:1.45rem;letter-spacing:0.15em;color:var(--ob-sienna);text-decoration:none;transition:color 0.2s;}
.ob-logo:hover{color:var(--ob-khaki);}
.ob-logo-img{height:36px;width:auto;object-fit:contain;}
.ob-nav-links{display:flex;gap:2rem;list-style:none;margin:0;padding:0;}
.ob-nav-links a{font-size:0.7rem;font-weight:500;letter-spacing:0.18em;text-transform:uppercase;color:rgba(240,235,224,0.85);text-decoration:none;transition:color 0.2s;}
.ob-nav-links a:hover{color:var(--ob-khaki);}
.ob-nav-cart{font-size:0.7rem;letter-spacing:0.12em;text-transform:uppercase;color:#fff;background:var(--ob-sienna);border:none;padding:0.5rem 1.25rem;border-radius:30px;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:500;text-decoration:none;display:inline-flex;align-items:center;transition:background 0.2s,transform 0.2s;}
.ob-nav-cart:hover{background:#9a4e1e;transform:scale(1.04);color:#fff;}
@media(max-width:900px){.ob-header{top:0.5rem;width:calc(100% - 1.2rem);padding:0.7rem 1.1rem;}.ob-nav-links{display:none;}}
</style>

{% schema %}
{
  "name": "OB Floating Header",
  "settings": [
    { "type": "image_picker", "id": "logo_image", "label": "Logo Image (optional)" },
    { "type": "text",         "id": "logo_text",  "label": "Logo Text", "default": "Outdoor Bills" }
  ],
  "presets": [{ "name": "OB Floating Header" }]
}
{% endschema %}
