{% comment %}
  OUTDOOR BILLS — Floating Footer | sections/ob-floating-footer.liquid
  Add to layout/theme.liquid just before </body>: {% section 'ob-floating-footer' %}
{% endcomment %}
<div class="ob-footer-wrap">
  <footer class="ob-footer">
    <div class="ob-footer-top">
      <div class="ob-footer-brand">
        <a href="{{ routes.root_url }}" class="ob-footer-logo">{{ section.settings.logo_text | default: shop.name }}</a>
        <p>For your next adventure.</p>
        <div class="ob-footer-soc">
          <a href="https://instagram.com/outdoorbills" target="_blank" rel="noopener" aria-label="Instagram">IG</a>
          <a href="https://www.youtube.com/@bill_leroy" target="_blank" rel="noopener" aria-label="YouTube">YT</a>
          <a href="https://tiktok.com/@outdoorbills" target="_blank" rel="noopener" aria-label="TikTok">TK</a>
        </div>
      </div>

      <!-- Shop column -->
      <div class="ob-footer-col">
        <h4>Shop</h4>
        <ul>
          <li><a href="/collections/all">All Products</a></li>
          <li><a href="/collections/hats">Hats &amp; Caps</a></li>
          <li><a href="/collections/apparel">Apparel</a></li>
          <li><a href="/collections/accessories">Accessories</a></li>
        </ul>
      </div>

      <!-- About column -->
      <div class="ob-footer-col">
        <h4>About</h4>
        <ul>
          <li><a href="/pages/about">Our Story</a></li>
          <li><a href="https://www.youtube.com/@bill_leroy" target="_blank" rel="noopener">YouTube</a></li>
          <li><a href="/blogs/news">Journal</a></li>
          <li><a href="https://sandlotrevival.org" target="_blank" rel="noopener">Sandlot Revival</a></li>
        </ul>
      </div>

      <!-- Connect column -->
      <div class="ob-footer-col">
        <h4>Connect</h4>
        <ul>
          <li><a href="https://instagram.com/outdoorbills" target="_blank" rel="noopener">Instagram</a></li>
          <li><a href="/pages/contact">Contact Us</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/policies/shipping-policy">Shipping</a></li>
          <li><a href="/policies/refund-policy">Returns</a></li>
        </ul>
      </div>
    </div>
    <div class="ob-footer-bottom">
      <span>© {{ 'now' | date: '%Y' }} Outdoor Bills. All rights reserved.</span>
      <span>Made for every adventure ✦</span>
    </div>
  </footer>
</div>
<style>
.ob-footer-wrap{background:var(--ob-cream);padding:2rem 1.5rem 1.5rem;}
.ob-footer{background:var(--ob-earth);border-radius:20px;padding:3.5rem 3.5rem 2rem;position:relative;overflow:hidden;}
.ob-footer::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--ob-sienna),var(--ob-river),var(--ob-moss),var(--ob-khaki));}
.ob-footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:2.5rem;padding-bottom:2.5rem;border-bottom:1px solid rgba(255,255,255,0.07);margin-bottom:1.8rem;}
.ob-footer-logo{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:0.15em;color:var(--ob-sienna);text-decoration:none;display:block;margin-bottom:0.9rem;transition:color 0.2s;}
.ob-footer-logo:hover{color:var(--ob-khaki);}
.ob-footer-brand p{font-family:'Libre Baskerville',serif;font-style:italic;font-size:0.86rem;color:rgba(240,235,224,0.45);line-height:1.7;max-width:240px;}
.ob-footer-soc{display:flex;gap:0.8rem;margin-top:1.4rem;}
.ob-footer-soc a{width:34px;height:34px;border:1px solid rgba(240,235,224,0.15);border-radius:50%;display:flex;align-items:center;justify-content:center;color:rgba(240,235,224,0.45);text-decoration:none;font-size:0.72rem;font-weight:500;transition:border-color 0.2s,color 0.2s;}
.ob-footer-soc a:hover{border-color:var(--ob-khaki);color:var(--ob-khaki);}
.ob-footer-col h4{font-family:'Bebas Neue',sans-serif;font-size:0.95rem;letter-spacing:0.22em;color:var(--ob-khaki);margin-bottom:1rem;}
.ob-footer-col ul{list-style:none;padding:0;margin:0;}
.ob-footer-col li{margin-bottom:0.55rem;}
.ob-footer-col a{color:rgba(240,235,224,0.45);text-decoration:none;font-size:0.82rem;transition:color 0.2s;}
.ob-footer-col a:hover{color:rgba(240,235,224,0.9);}
.ob-footer-bottom{display:flex;align-items:center;justify-content:space-between;font-size:0.7rem;color:rgba(240,235,224,0.22);letter-spacing:0.1em;flex-wrap:wrap;gap:0.5rem;}
.ob-footer-bottom span:last-child{color:rgba(196,170,122,0.38);}
@media(max-width:900px){.ob-footer-top{grid-template-columns:1fr 1fr;}.ob-footer{padding:2.5rem 1.5rem 1.5rem;border-radius:12px;}}
@media(max-width:500px){.ob-footer-top{grid-template-columns:1fr;}}
</style>
{% schema %}
{
  "name": "OB Floating Footer",
  "settings": [
    { "type": "text", "id": "logo_text", "label": "Logo Text", "default": "Outdoor Bills" }
  ],
  "presets": [{ "name": "OB Floating Footer" }]
}
{% endschema %}
