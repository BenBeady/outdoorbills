{% comment %}OUTDOOR BILLS — About Mission | sections/ob-about-mission.liquid{% endcomment %}
<section class="ob-mission">
  <div class="ob-mission-inner ob-reveal">
    <span class="ob-label" style="color:var(--ob-peach);">{{ section.settings.eyebrow | default: 'Our Mission' }}</span>
    <h2 class="ob-mission-title">{{ section.settings.title | default: 'Finding Joy — For Your Next Adventure' }}</h2>
    <p class="ob-mission-body">{{ section.settings.body | default: 'We believe time spent in nature changes you. It slows you down, connects you to what matters, and reminds you that the best things in life happen outside. Outdoor Bills exists to outfit that life and celebrate it.' }}</p>
    <div class="ob-mission-vals">
      <div class="ob-mission-val ob-reveal">
        <span class="ob-mission-icon">🎣</span>
        <h4>{{ section.settings.val1_title | default: 'Fish On' }}</h4>
        <p>{{ section.settings.val1_text | default: 'On the water from first light, chasing the catch wherever it takes us.' }}</p>
      </div>
      <div class="ob-mission-val ob-reveal ob-d1">
        <span class="ob-mission-icon">🦌</span>
        <h4>{{ section.settings.val2_title | default: 'Hunt More' }}</h4>
        <p>{{ section.settings.val2_text | default: 'In the field at dawn. Patience, tradition, and the thrill of the wild.' }}</p>
      </div>
      <div class="ob-mission-val ob-reveal ob-d2">
        <span class="ob-mission-icon">🌿</span>
        <h4>{{ section.settings.val3_title | default: 'Get Outdoors' }}</h4>
        <p>{{ section.settings.val3_text | default: 'Any trail, any terrain. Life is better outside — go find it.' }}</p>
      </div>
      <div class="ob-mission-val ob-reveal ob-d3">
        <span class="ob-mission-icon">🙏</span>
        <h4>{{ section.settings.val4_title | default: 'Find Joy' }}</h4>
        <p>{{ section.settings.val4_text | default: 'Faith, community, and the outdoors. That\'s what this is about.' }}</p>
      </div>
    </div>
  </div>
</section>
<style>
.ob-mission{background:var(--ob-earth);padding:6rem 3.5rem;text-align:center;}
.ob-mission-inner{max-width:960px;margin:0 auto;}
.ob-mission-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,4.5vw,3.8rem);line-height:1.05;color:#fff;margin:0.5rem 0 1.2rem;letter-spacing:0.02em;}
.ob-mission-body{font-family:'Libre Baskerville',serif;font-style:italic;font-size:1rem;line-height:1.9;color:rgba(240,235,224,0.58);max-width:660px;margin:0 auto 3.5rem;}
.ob-mission-vals{display:grid;grid-template-columns:repeat(4,1fr);gap:1.5rem;text-align:left;}
.ob-mission-val{background:rgba(255,255,255,0.04);border:1px solid rgba(196,170,122,0.12);border-radius:6px;padding:1.8rem 1.5rem;transition:border-color 0.3s;}
.ob-mission-val:hover{border-color:rgba(196,170,122,0.3);}
.ob-mission-icon{font-size:1.7rem;display:block;margin-bottom:0.65rem;}
.ob-mission-val h4{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:0.1em;color:var(--ob-khaki);margin-bottom:0.4rem;}
.ob-mission-val p{font-family:'DM Sans',sans-serif;font-size:0.8rem;color:rgba(240,235,224,0.45);line-height:1.6;margin:0;}
@media(max-width:900px){.ob-mission{padding:4rem 1.5rem;}.ob-mission-vals{grid-template-columns:repeat(2,1fr);}}
@media(max-width:500px){.ob-mission-vals{grid-template-columns:1fr;}}
</style>
{% schema %}
{
  "name": "OB About — Mission",
  "settings": [
    { "type": "text",     "id": "eyebrow",    "label": "Eyebrow",        "default": "Our Mission" },
    { "type": "text",     "id": "title",      "label": "Title",          "default": "Finding Joy — For Your Next Adventure" },
    { "type": "textarea", "id": "body",       "label": "Body Text",      "default": "We believe time spent in nature changes you. It slows you down, connects you to what matters, and reminds you that the best things in life happen outside." },
    { "type": "header",   "content": "Pillar 1" },
    { "type": "text",     "id": "val1_title", "label": "Title",          "default": "Fish On" },
    { "type": "text",     "id": "val1_text",  "label": "Description",    "default": "On the water from first light, chasing the catch wherever it takes us." },
    { "type": "header",   "content": "Pillar 2" },
    { "type": "text",     "id": "val2_title", "label": "Title",          "default": "Hunt More" },
    { "type": "text",     "id": "val2_text",  "label": "Description",    "default": "In the field at dawn. Patience, tradition, and the thrill of the wild." },
    { "type": "header",   "content": "Pillar 3" },
    { "type": "text",     "id": "val3_title", "label": "Title",          "default": "Get Outdoors" },
    { "type": "text",     "id": "val3_text",  "label": "Description",    "default": "Any trail, any terrain. Life is better outside — go find it." },
    { "type": "header",   "content": "Pillar 4" },
    { "type": "text",     "id": "val4_title", "label": "Title",          "default": "Find Joy" },
    { "type": "text",     "id": "val4_text",  "label": "Description",    "default": "Faith, community, and the outdoors. That's what this is about." }
  ],
  "presets": [{ "name": "OB About — Mission" }]
}
{% endschema %}
