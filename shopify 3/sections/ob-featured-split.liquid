{% comment %}OUTDOOR BILLS — Featured Split | sections/ob-featured-split.liquid{% endcomment %}
<section class="ob-featured">
  <div class="ob-feat-text ob-reveal">
    <span class="ob-label">{{ section.settings.eyebrow }}</span>
    <h2 class="ob-title">{{ section.settings.title_plain }} <em>{{ section.settings.title_italic }}</em></h2>
    <div class="ob-divider"></div>
    <p>{{ section.settings.body_text }}</p>
    <div class="ob-feat-btns">
      <a href="/collections/all" class="ob-btn">View All</a>
      <a href="/collections/all" class="ob-btn-out">Shop Now</a>
    </div>
  </div>
  <div class="ob-feat-img">
    {% if section.settings.featured_image %}
      <img src="{{ section.settings.featured_image | img_url: '900x' }}" alt="{{ section.settings.image_alt }}"/>
    {% endif %}
    <div class="ob-feat-overlay">
      <span class="ob-feat-tag">{{ section.settings.image_tag }}</span>
      <a href="/collections/all" class="ob-feat-name">{{ section.settings.image_name }}</a>
    </div>
  </div>
</section>
<style>
.ob-featured{display:grid;grid-template-columns:1fr 1fr;min-height:88vh;}
.ob-feat-text{background:var(--ob-card);display:flex;flex-direction:column;justify-content:center;padding:5rem 4.5rem;position:relative;overflow:hidden;}
.ob-feat-text::before{content:'OB';position:absolute;bottom:-2rem;right:-1.5rem;font-family:'Bebas Neue',sans-serif;font-size:20rem;color:rgba(59,92,114,0.04);line-height:1;pointer-events:none;}
.ob-feat-text p{font-family:'Libre Baskerville',serif;font-size:1rem;line-height:1.85;color:var(--ob-muted);margin:1.3rem 0 2.2rem;max-width:370px;}
.ob-feat-btns{display:flex;gap:1rem;flex-wrap:wrap;}
.ob-feat-img{position:relative;overflow:hidden;min-height:500px;background:var(--ob-earth);}
.ob-feat-img img{width:100%;height:100%;object-fit:cover;transition:transform 0.6s;filter:saturate(0.92);}
.ob-feat-img:hover img{transform:scale(1.04);filter:saturate(1.05);}
.ob-feat-overlay{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(to top,rgba(42,31,20,0.82),transparent);padding:2rem;}
.ob-feat-tag{display:inline-block;background:var(--ob-sienna);color:#fff;font-size:0.6rem;letter-spacing:0.22em;text-transform:uppercase;padding:0.28rem 0.75rem;margin-bottom:0.45rem;border-radius:2px;}
.ob-feat-name{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:0.08em;color:#fff;text-decoration:none;display:block;transition:color 0.2s;}
.ob-feat-name:hover{color:var(--ob-khaki);}
@media(max-width:900px){.ob-featured{grid-template-columns:1fr;}.ob-feat-img{min-height:320px;}.ob-feat-text{padding:3rem 1.5rem;}.ob-feat-text::before{display:none;}}
</style>
{% schema %}{"name":"OB Featured Split","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"New Arrival"},{"type":"text","id":"title_plain","label":"Title (plain)","default":"Check"},{"type":"text","id":"title_italic","label":"Title (italic)","default":"This Out"},{"type":"textarea","id":"body_text","label":"Body Text","default":"Gear and apparel made for people who'd rather be on the water or in the woods. Every piece carries the spirit of adventure."},{"type":"image_picker","id":"featured_image","label":"Feature Image"},{"type":"text","id":"image_alt","label":"Image Alt","default":"Featured product"},{"type":"text","id":"image_tag","label":"Image Badge","default":"Best Seller"},{"type":"text","id":"image_name","label":"Image Caption","default":"OB Original Cap"}],"presets":[{"name":"OB Featured Split"}]}{% endschema %}
