{% comment %}OUTDOOR BILLS — Newsletter | sections/ob-newsletter.liquid{% endcomment %}
<section class="ob-nl">
  <div class="ob-reveal">
    <span class="ob-label" style="color:rgba(196,170,122,0.9);">{{ section.settings.eyebrow }}</span>
    <h2 class="ob-nl-title">{{ section.settings.title_plain }} <em>{{ section.settings.title_italic }}</em></h2>
    <p>{{ section.settings.subtitle }}</p>
  </div>
  <div class="ob-nl-form ob-reveal ob-d2">
    {% form 'customer', id: 'ob-nl-form' %}
      <input type="hidden" name="contact[tags]" value="newsletter"/>
      <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" autocomplete="email" required/>
      <button type="submit">{{ section.settings.button_text }}</button>
      {% if form.posted_successfully? %}<p class="ob-nl-ok">✓ You're in!</p>{% endif %}
    {% endform %}
  </div>
</section>
<style>
.ob-nl{background:var(--ob-moss);padding:5rem 3.5rem;display:flex;align-items:center;justify-content:space-between;gap:3rem;flex-wrap:wrap;}
.ob-nl-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(1.8rem,3.5vw,2.8rem);line-height:1;color:#fff;margin:0.3rem 0 0.4rem;}
.ob-nl-title em{font-family:'Playfair Display',serif;font-style:italic;color:var(--ob-khaki);}
.ob-nl p{font-family:'Libre Baskerville',serif;font-style:italic;color:rgba(240,235,224,0.7);}
.ob-nl-form{display:flex;flex-direction:column;gap:0.5rem;max-width:460px;width:100%;}
.ob-nl-form form{display:flex;}
.ob-nl-form input[type="email"]{flex:1;padding:1rem 1.4rem;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.25);border-right:none;color:#fff;font-family:'DM Sans',sans-serif;font-size:0.88rem;outline:none;transition:border-color 0.2s;}
.ob-nl-form input[type="email"]::placeholder{color:rgba(240,235,224,0.4);}
.ob-nl-form input[type="email"]:focus{border-color:var(--ob-khaki);}
.ob-nl-form button{padding:1rem 1.6rem;background:var(--ob-sienna);border:none;color:#fff;font-family:'DM Sans',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;cursor:pointer;transition:background 0.2s;white-space:nowrap;}
.ob-nl-form button:hover{background:#9a4e1e;}
.ob-nl-ok{color:#90EE90;font-size:0.85rem;margin:0.5rem 0 0;font-family:'DM Sans',sans-serif;}
@media(max-width:700px){.ob-nl{padding:3rem 1.5rem;flex-direction:column;}.ob-nl-form{max-width:100%;}}
</style>
{% schema %}{"name":"OB Newsletter","settings":[{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Stay In Touch"},{"type":"text","id":"title_plain","label":"Title (plain)","default":"Sign Up For"},{"type":"text","id":"title_italic","label":"Title (italic)","default":"Updates"},{"type":"text","id":"subtitle","label":"Subtitle","default":"New drops, adventures, and stories from the field."},{"type":"text","id":"placeholder","label":"Placeholder","default":"Enter your email address"},{"type":"text","id":"button_text","label":"Button Text","default":"Subscribe"}],"presets":[{"name":"OB Newsletter"}]}{% endschema %}
