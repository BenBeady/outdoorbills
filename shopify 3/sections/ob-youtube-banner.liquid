{% comment %}OUTDOOR BILLS — YouTube / Video Background | sections/ob-youtube-banner.liquid
Linked to https://www.youtube.com/@bill_leroy (Outdoor Bills / Bill Leroy)
{% endcomment %}
<section class="ob-yt">
  {% if section.settings.video_url != blank %}
    <video class="ob-yt-video" id="ob-yt-video" autoplay muted loop playsinline
      src="{{ section.settings.video_url }}"
      {% if section.settings.bg_image %}poster="{{ section.settings.bg_image | img_url: '1800x' }}"{% endif %}>
    </video>
    <div class="ob-yt-imgbg" id="ob-yt-fallback" {% if section.settings.bg_image %}style="background-image:url('{{ section.settings.bg_image | img_url: '1800x' }}');display:none;"{% else %}style="display:none;"{% endif %}></div>
  {% else %}
    <div class="ob-yt-imgbg" {% if section.settings.bg_image %}style="background-image:url('{{ section.settings.bg_image | img_url: '1800x' }}');"{% endif %}></div>
  {% endif %}
  <div class="ob-yt-tint"></div>
  <div class="ob-yt-content ob-reveal">
    <span class="ob-label" style="color:var(--ob-peach);display:block;margin-bottom:0.5rem;">{{ section.settings.eyebrow }}</span>
    <h2 class="ob-yt-title">{{ section.settings.title_plain }} <em>{{ section.settings.title_italic }}</em></h2>
    <p>{{ section.settings.subtitle }}</p>
    <a href="https://www.youtube.com/@bill_leroy" class="ob-yt-btn" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="white"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      {{ section.settings.button_text }}
    </a>
  </div>
</section>
<style>
.ob-yt{position:relative;height:520px;overflow:hidden;display:flex;align-items:center;justify-content:center;background:var(--ob-earth);}
.ob-yt-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;pointer-events:none;filter:brightness(0.3) saturate(0.55);}
.ob-yt-imgbg{position:absolute;inset:0;background-size:cover;background-position:center;background-color:var(--ob-earth);filter:brightness(0.3) saturate(0.55);}
.ob-yt-tint{position:absolute;inset:0;background:linear-gradient(135deg,rgba(59,92,114,0.3),rgba(74,103,65,0.22));}
.ob-yt-content{position:relative;z-index:2;text-align:center;padding:0 2rem;}
.ob-yt-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.8rem,6vw,6rem);line-height:0.95;color:#fff;margin:0.4rem 0 0.6rem;}
.ob-yt-title em{font-family:'Playfair Display',serif;font-style:italic;color:var(--ob-khaki);}
.ob-yt-content p{font-family:'Libre Baskerville',serif;font-style:italic;color:rgba(240,235,224,0.72);margin-bottom:2rem;font-size:1rem;}
.ob-yt-btn{display:inline-flex;align-items:center;gap:0.65rem;padding:1rem 2.5rem;background:#FF0000;color:#fff;font-family:'DM Sans',sans-serif;font-size:0.8rem;font-weight:500;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;border-radius:2px;transition:background 0.2s,transform 0.2s;}
.ob-yt-btn:hover{background:#cc0000;transform:translateY(-2px);color:#fff;}
</style>
{% schema %}{"name":"OB YouTube / Video","settings":[{"type":"text","id":"video_url","label":"Video File URL (.mp4)","info":"Upload in Shopify Admin → Content → Files, paste URL here. Leave blank to use image only."},{"type":"image_picker","id":"bg_image","label":"Fallback Background Image"},{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Watch & Subscribe"},{"type":"text","id":"title_plain","label":"Title (plain)","default":"On The"},{"type":"text","id":"title_italic","label":"Title (italic)","default":"Channel"},{"type":"text","id":"subtitle","label":"Subtitle","default":"Fishing, hunting & outdoor adventures from around the world"},{"type":"text","id":"button_text","label":"Button Text","default":"Watch on YouTube"}],"presets":[{"name":"OB YouTube / Video"}]}{% endschema %}
